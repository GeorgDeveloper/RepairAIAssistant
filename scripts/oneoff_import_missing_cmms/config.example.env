# Скопируйте в config.env и заполните (config.env в .gitignore не добавляем — не коммитьте пароли)

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=monitoring_bd
MYSQL_USER=dba
MYSQL_PASSWORD=dbaPass

# CMMS / SQL Server (рекомендуется — иначе mechanism_node, maintainers, STTR останутся пустыми)
CMMS_HOST=172.21.219.149
CMMS_PORT=1433
CMMS_DATABASE=CMMS
CMMS_USER=cmms_readonly
CMMS_PASSWORD=your_cmms_password
# Оставьте пустым для автовыбора (17 → 18 → SQL Server)
CMMS_ODBC_DRIVER=ODBC Driver 17 for SQL Server
